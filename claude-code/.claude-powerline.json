{
	"theme": "rose-pine",
	"display": {
		"padding": 1,
		"style": "capsule",
		"charset": "unicode",
		"autoWrap": false,
		"lines": [
			{
				"segments": {
					"directory": {
						"enabled": true,
						"style": "basename"
					},
					"git": {
						"enabled": true,
						"showSha": false,
						"showWorkingTree": false,
						"showRepoName": false,
						"showOperation": false,
						"showTag": false,
						"showTimeSinceCommit": false,
						"showStashCount": false,
						"showUpstream": false
					},
					"model": {
						"enabled": true
					},
					"context": {
						"enabled": true,
						"showPercentageOnly": true,
						"displayStyle": "percentage"
					}
				}
			},
			{
				"segments": {}
			},
			{
				"segments": {
					"block": {
						"enabled": true,
						"type": "tokens",
						"burnType": "tokens"
					}
				}
			}
		]
	},
	"budget": {
		"block": null
	}
}
