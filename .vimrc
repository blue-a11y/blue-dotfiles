" =============================================================================
" 1. 核心兼容性与显示 (Core & Display)
" =============================================================================
set nocompatible              " 开启现代模式
filetype plugin indent on     " 自动识别文件类型
syntax on                     " 语法高亮
set mouse=a                   " 开启鼠标支持
set clipboard=unnamed         " macOS 剪贴板同步

set number                    " 显示行号
set laststatus=2              " 始终显示状态栏
set scrolloff=8               " 滚动时上下保留 8 行视野

" =============================================================================
" 2. 前端缩进规范 (Indentation)
" =============================================================================
set tabstop=2                 " Tab 占 2 空格
set shiftwidth=2              " 自动缩进 2 空格
set expandtab                 " Tab 转空格
set autoindent                " 自动缩进
set smartindent               " 智能缩进

" =============================================================================
" 3. 搜索优化 (Search)
" =============================================================================
set hlsearch                  " 高亮搜索
set incsearch                 " 实时跳转
set ignorecase                " 忽略大小写
set smartcase                 " 大写字母敏感
